---
layout: layout.liquid
title: Verdance | Apply Now
permalink: /apply-now/
---

<div class="apply-now-page">
    <section class="section--spacing section--bg-linen">
        <div class="container">
            <div class="col-12">
                <div class="apply-now-form">
                    <form class="apply-now-form__body">
                        <div class="apply-now-form__row">
                            <label for="name-first" class="apply-now-form__label">
                                1. Veteran/Service Member's Name (First, Middle Initial, Last)
                            </label>
                            <div class="apply-now-form__name-grid">
                                <input id="name-first" name="nameFirst" type="text" maxlength="24" />
                                <input id="name-middle" name="nameMiddle" type="text" maxlength="2" />
                                <input id="name-last" name="nameLast" type="text" maxlength="24" />
                            </div>
                        </div>

                        <div class="apply-now-form__row">
                            <label for="ssn-1" class="apply-now-form__label">2. Social Security Number</label>
                            <div class="apply-now-form__inline">
                                <input id="ssn-1" name="ssn1" type="text" maxlength="3" />
                                <input id="ssn-2" name="ssn2" type="text" maxlength="2" />
                                <input id="ssn-3" name="ssn3" type="text" maxlength="4" />
                            </div>
                        </div>

                        <div class="apply-now-form__row">
                            <label for="va-file" class="apply-now-form__label">3. VA File Number (If applicable)</label>
                            <input id="va-file" name="vaFileNumber" type="text" maxlength="12" />
                        </div>

                        <div class="apply-now-form__row">
                            <label for="dob-mm" class="apply-now-form__label">4. Date of Birth (MM/DD/YYYY)</label>
                            <div class="apply-now-form__inline">
                                <input id="dob-mm" name="dobMonth" type="text" maxlength="2" />
                                <input id="dob-dd" name="dobDay" type="text" maxlength="2" />
                                <input id="dob-yyyy" name="dobYear" type="text" maxlength="4" />
                            </div>
                        </div>

                        <div class="apply-now-form__row">
                            <label for="service-number" class="apply-now-form__label">5. Veteran's Service Number (If applicable)</label>
                            <input id="service-number" name="serviceNumber" type="text" maxlength="12" />
                        </div>

                        <div class="apply-now-form__row">
                            <label for="phone-1" class="apply-now-form__label">6. Telephone Number (Include Area Code)</label>
                            <div class="apply-now-form__inline">
                                <input id="phone-1" name="phoneArea" type="text" maxlength="3" />
                                <input id="phone-2" name="phoneExchange" type="text" maxlength="3" />
                                <input id="phone-3" name="phoneLine" type="text" maxlength="4" />
                            </div>
                            <label for="intl-phone" class="apply-now-form__sub-label">
                                Enter International Phone Number (If applicable)
                            </label>
                            <input id="intl-phone" name="intlPhone" type="text" maxlength="24" />
                        </div>

                        <div class="apply-now-form__row">
                            <label for="email" class="apply-now-form__label">7. E-mail Address (Optional)</label>
                            <input id="email" name="email" type="email" maxlength="120" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>
</div>
